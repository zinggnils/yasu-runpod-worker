# May 4 MVP — set on RunPod endpoint (Settings → Environment variables)
# Good run: decode → MODNet → redness → DB, Input size (1920, 1008), no face crop / quality gate

ENABLE_FACE_CROP=false
ENABLE_QUALITY_GATE=false
ENABLE_INPUT_NORMALIZE=false
BG_REMOVAL_BACKEND=modnet

# Required (from Supabase project settings)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
